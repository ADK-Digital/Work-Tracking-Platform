NODE_ENV=production
PORT=3000

# Public URLs
FRONTEND_URL=http://pm.local
ALLOWED_EMAIL_DOMAINS=yourdistrict.org

# Database (compose should match this)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/app?schema=public

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ATTACHMENTS=attachments

# Auth (later phases)
AUTH_ENABLED=false
SESSION_SECRET=change_me_long_random
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=

# RBAC (later phases)
RBAC_ENABLED=false
RBAC_ADMIN_GROUP=
RBAC_TECH_GROUP=