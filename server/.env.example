# Local Postgres from docker-compose.yml in repo root
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/special_projects?schema=public"
PORT=3001
SESSION_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"
ALLOWED_EMAIL_DOMAINS="yourdistrict.org"
ALLOWED_USER_GROUPS=""
ADMIN_GROUPS=""
ADMIN_EMAILS="admin@yourdistrict.org"
GOOGLE_WORKSPACE_CUSTOMER_ID=""
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_IMPERSONATE_ADMIN_EMAIL=""
FRONTEND_URL="http://localhost:5173"

# Attachment storage (S3-compatible, MinIO)
S3_ENDPOINT="http://minio:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="attachments"
S3_FORCE_PATH_STYLE="true"
ATTACHMENT_MAX_SIZE_BYTES="26214400"
ATTACHMENT_ALLOWED_TYPES="application/pdf,image/png,image/jpeg,image/gif,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel"
