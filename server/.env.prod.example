NODE_ENV=production
PORT=3001
TRUST_PROXY=true
DATABASE_URL=postgresql://postgres:postgres@db:5432/special_projects?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=special_projects

SESSION_SECRET=replace-with-long-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-internal-host/auth/google/callback

FRONTEND_URL=https://your-internal-host
ALLOWED_EMAIL_DOMAINS=yourdistrict.org
ALLOWED_USER_GROUPS=
ADMIN_GROUPS=
ADMIN_EMAILS=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_IMPERSONATE_ADMIN_EMAIL=
GOOGLE_WORKSPACE_CUSTOMER_ID=

# MinIO / S3 attachment storage
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=replace-with-strong-minio-password
S3_BUCKET=attachments
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
ATTACHMENT_MAX_SIZE_BYTES=26214400
ATTACHMENT_ALLOWED_TYPES=application/pdf,image/png,image/jpeg,image/gif,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel
