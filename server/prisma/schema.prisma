generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkItemType {
  task
  purchase_request
}

enum ActivityEventType {
  created
  updated
  status_changed
  owner_changed
  deleted
  restored
  attachment_added
  attachment_deleted
}

model WorkItem {
  id          String          @id @default(uuid())
  type        WorkItemType
  title       String
  description String?
  status      String
  ownerGoogleId String
  ownerEmail    String
  ownerName     String
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  activityEvents ActivityEvent[]
  comments       Comment[]
  attachments    Attachment[]

  @@index([updatedAt])
  @@index([type])
  @@index([status])
  @@index([ownerGoogleId])
  @@index([ownerEmail])
}

model Attachment {
  id          String   @id @default(uuid())
  workItemId  String
  filename    String
  contentType String
  sizeBytes   Int
  storageKey  String   @unique
  uploadedBy  String
  uploadedAt  DateTime @default(now())
  deletedAt   DateTime?
  deletedBy   String?

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId, uploadedAt])
}

model ActivityEvent {
  id         String            @id @default(uuid())
  workItemId String
  type       ActivityEventType
  message    String
  timestamp  DateTime          @default(now())
  actor      String?

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
  @@index([workItemId, timestamp])
}

model Comment {
  id          String   @id @default(uuid())
  workItemId  String
  body        String
  authorEmail String
  authorName  String?
  createdAt   DateTime @default(now())
  deletedAt   DateTime?
  deletedBy   String?

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId, createdAt])
}
